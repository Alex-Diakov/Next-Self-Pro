# ==========================================
# Stage 1: Build (Сборка приложения)
# ==========================================
FROM node:20-alpine AS builder

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы зависимостей
COPY package*.json ./

# Устанавливаем ВСЕ зависимости (включая devDependencies для сборки)
RUN npm ci

# Копируем весь исходный код
COPY . .

# Собираем клиентскую и серверную части (создается папка dist)
RUN npm run build

# ==========================================
# Stage 2: Production (Финальный образ)
# ==========================================
FROM node:20-alpine AS runner

WORKDIR /app

# Устанавливаем переменную окружения для продакшена
ENV NODE_ENV=production

# Копируем файлы зависимостей
COPY package*.json ./

# Устанавливаем ТОЛЬКО продакшен-зависимости (без devDependencies)
RUN npm ci --omit=dev

# Копируем скомпилированные файлы из первого этапа
COPY --from=builder /app/dist ./dist

# Открываем порт 3000 (стандартный для нашего сервера)
EXPOSE 3000

# Запускаем приложение
CMD ["npm", "start"]
